# Copy this file to .env.production and fill in the values.
# NEVER commit .env.production to version control.

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_USER=goldeneye
POSTGRES_PASSWORD=changeme
POSTGRES_DB=goldeneye

# ── Hono server ───────────────────────────────────────────────────────────────
# Must be >= 32 characters. Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=

# Public URL of the API (used by better-auth for cookie domain / email links).
# Because Nginx proxies /api/* from the same origin, this is the same domain
# as CORS_ORIGIN.
BETTER_AUTH_URL=https://example.com

# Public-facing domain of the web app — used by the server for CORS.
CORS_ORIGIN=https://example.com

# ── React web app (baked into the Vite bundle at build time) ──────────────────
# Set to "" to use relative /api/* paths (recommended when Nginx proxies /api/*).
# Set to "https://example.com" if you need absolute API URLs for some reason.
VITE_SERVER_URL=
