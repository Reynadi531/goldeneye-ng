{
  "name": "server",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "build": "tsdown",
    "check-types": "tsc -b",
    "compile": "bun build --compile --minify --sourcemap --bytecode ./src/index.ts --outfile server",
    "dev": "bun run --hot src/index.ts",
    "start": "bun run dist/index.mjs",
    "db:seed": "bun run seed.ts"
  },
  "dependencies": {
    "@goldeneye-ng/auth": "workspace:*",
    "@goldeneye-ng/cache": "workspace:*",
    "@goldeneye-ng/db": "workspace:*",
    "@goldeneye-ng/env": "workspace:*",
    "@hono/node-server": "^1.19.11",
    "@node-rs/argon2": "^2.0.2",
    "better-auth": "catalog:",
    "dotenv": "catalog:",
    "hono": "^4.8.2",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@goldeneye-ng/config": "workspace:*",
    "@types/bun": "catalog:",
    "tsdown": "^0.16.5",
    "typescript": "^5"
  }
}
