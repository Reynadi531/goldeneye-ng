# syntax=docker/dockerfile:1

# ─── Stage 1: builder ────────────────────────────────────────────────────────
FROM oven/bun:1.3.10-alpine AS builder

WORKDIR /app

# VITE_SERVER_URL must be provided at build time because Vite bakes env vars
# into the bundle (they cannot be injected at container runtime).
# Pass it via: docker build --build-arg VITE_SERVER_URL=https://example.com
ARG VITE_SERVER_URL
ENV VITE_SERVER_URL=$VITE_SERVER_URL

# Copy manifests first for better layer caching.
# All workspace package.json files must be present before `bun install` so
# Bun can resolve the full workspace graph (it errors on any missing member).
COPY package.json bun.lock turbo.json tsconfig.json ./
COPY apps/web/package.json    ./apps/web/
COPY apps/server/package.json ./apps/server/
COPY packages/auth/package.json   ./packages/auth/
COPY packages/db/package.json     ./packages/db/
COPY packages/env/package.json    ./packages/env/
COPY packages/ui/package.json     ./packages/ui/
COPY packages/config/package.json ./packages/config/

# Install all workspace dependencies
RUN bun install --frozen-lockfile

# Copy all source
COPY apps/web/ ./apps/web/
COPY packages/ ./packages/

# Build the SPA
RUN bun run --cwd apps/web build

# ─── Stage 2: runner ─────────────────────────────────────────────────────────
FROM nginx:1.27-alpine AS runner

# Remove default Nginx static content
RUN rm -rf /usr/share/nginx/html/*

# Copy SPA build output
COPY --from=builder /app/apps/web/dist /usr/share/nginx/html

# Copy custom Nginx config (SPA routing + /api reverse proxy)
COPY nginx.conf /etc/nginx/conf.d/default.conf

EXPOSE 80

CMD ["nginx", "-g", "daemon off;"]
