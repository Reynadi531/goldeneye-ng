{
  "name": "goldeneye-ng",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "dotenv": "^17.2.2",
      "zod": "^4.1.13",
      "@types/bun": "^1.3.4",
      "better-auth": "1.5.2",
      "lucide-react": "^0.546.0",
      "next-themes": "^0.4.6",
      "react": "^19.2.3",
      "react-dom": "^19.2.3",
      "sonner": "^2.0.5",
      "@types/react": "^19.2.10",
      "@types/react-dom": "^19.2.3",
      "tailwindcss": "^4.1.18"
    }
  },
  "type": "module",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "deploy": "turbo deploy",
    "deploy:server": "turbo -F server deploy",
    "deploy:web": "turbo -F web deploy",
    "check-types": "turbo check-types",
    "dev:web": "turbo -F web dev",
    "dev:server": "turbo -F server dev",
    "db:push": "turbo -F @goldeneye-ng/db db:push",
    "db:studio": "turbo -F @goldeneye-ng/db db:studio",
    "db:generate": "turbo -F @goldeneye-ng/db db:generate",
    "db:migrate": "turbo -F @goldeneye-ng/db db:migrate",
    "db:seed": "turbo -F server db:seed",
    "docker:db": "docker compose up -d",
    "docker:db:stop": "docker compose down",
    "check": "oxlint && oxfmt --write"
  },
  "dependencies": {
    "@goldeneye-ng/env": "workspace:*",
    "dotenv": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@goldeneye-ng/config": "workspace:*",
    "@types/bun": "catalog:",
    "lefthook": "^2.0.13",
    "oxfmt": "^0.26.0",
    "oxlint": "^1.41.0",
    "turbo": "^2.8.12",
    "typescript": "^5"
  },
  "packageManager": "bun@1.3.10"
}
