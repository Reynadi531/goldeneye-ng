# Caddyfile — place this on the host running Docker (e.g. /etc/caddy/Caddyfile)
# Replace "example.com" with your actual domain.
# Caddy handles TLS automatically via Let's Encrypt.

example.com {
    # Route API + auth traffic directly to the Hono server container
    handle /api/* {
        reverse_proxy localhost:3000
    }

    # Route everything else to the Nginx container serving the SPA
    handle {
        reverse_proxy localhost:8080
    }
}
